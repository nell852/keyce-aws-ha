        <mxCell id="tp2_note" parent="1" style="text;html=1;strokeColor=#0db7ed;fillColor=#EBF5FB;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11;fontColor=#0db7ed;spacingLeft=8;fontStyle=1;" value="TP2 — Éléments ajoutés :&lt;br&gt;- Odoo 17 Docker sur chaque EC2&lt;br&gt;- PostgreSQL 15 + Patroni (PRIMARY/STANDBY)&lt;br&gt;- etcd : arbitre cluster, élit le Leader&lt;br&gt;- EFS partagé : filestore commun aux 2 Odoo&lt;br&gt;- lsyncd bidirectionnel : réplication filestore&lt;br&gt;- ALB Odoo HA (alb-odoo-ha) :80&lt;br&gt;- Client Debian connecté via VPN Pritunl&lt;br&gt;- Hybridation réseau local ↔ AWS" vertex="1">
          <mxGeometry height="140" width="245" x="470" y="1070" as="geometry" />
        </mxCell>
