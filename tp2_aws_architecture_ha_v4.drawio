        <mxCell id="meta" parent="1" style="text;html=1;strokeColor=#AAB7B8;fillColor=#FDFEFE;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11;fontColor=#2C3E50;spacingLeft=8;" value="&lt;b&gt;Infos Projet&lt;/b&gt;&#xa;École  : Keyce Informatique&#xa;Promo  : B3 Réseaux &amp; Sécurité&#xa;Région : AWS us-east-1&#xa;VPC CIDR : 10.0.0.0/16&#xa;Auteur : Nell Mvele" vertex="1">
          <mxGeometry height="130" width="350" x="1850" y="1070" as="geometry" />
