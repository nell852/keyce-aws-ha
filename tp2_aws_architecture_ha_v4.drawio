        <mxCell id="sg_note" parent="1" style="text;html=1;strokeColor=#AAB7B8;fillColor=#FDFEFE;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11;fontColor=#2C3E50;spacingLeft=8;" value="&lt;b&gt;Security Groups&lt;/b&gt;&#xa;sg-ec2 (sg-005f7219e0e06dd28) : 22/SSH · 80/HTTP · 8069/Odoo · 8008/Patroni · 2379/etcd · 1194/UDP&#xa;alb-odoo-sg (sg-0fbe285a50924782c) : 80/HTTP (source: 0.0.0.0/0)&#xa;efs-odoo-sg : 2049/NFS (source: sg-ec2)&#xa;rds-odoo-sg : 5432/PostgreSQL (source: sg-ec2)" vertex="1">
